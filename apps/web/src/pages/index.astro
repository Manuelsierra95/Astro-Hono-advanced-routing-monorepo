---
import { client } from '@/lib/client'
import Layout from '@/layouts/Layout.astro'
import Button from '@workspace/ui/components/button'
import {
  Card,
  CardHeader,
  CardContent,
  CardFooter,
  CardTitle,
  CardDescription,
} from '@workspace/ui/components/card'
import Spinner from '@workspace/ui/components/spinner'

const url = new URL(Astro.request.url)
const token = url.searchParams.get('token')

let activities = null

if (token) {
  try {
    const res = await client.api.auth.activities.$get({
      query: { token },
    })

    const raw = await res.json()

    console.log('Activities response', raw)
    activities = raw.map(formatActivity)
  } catch (e) {
    console.error('Error loading activities', e)
  }
}

function formatActivity(a: any) {
  return {
    id: a.id,
    name: a.name,
    date: new Date(a.start_date_local).toLocaleDateString(),

    distance_km: (a.distance / 1000).toFixed(2),
    elevation_m: a.total_elevation_gain,
    duration_min: Math.round(a.moving_time / 60),

    avg_speed_kmh: (a.average_speed * 3.6).toFixed(1),
    avg_hr: a.average_heartrate,
  }
}
---

<Layout>
  <main
    class="mx-auto flex min-h-screen w-full max-w-5xl items-center px-6 py-16"
  >
    <section
      class="grid w-full gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center"
    >
      <div class="space-y-6">
        <h1 class="text-5xl font-semibold">Integración con Strava</h1>

        <Button href="/api/auth/strava" variant="primary" size="md">
          Conectar con Strava
        </Button>
      </div>

      <Card class="overflow-hidden">
        <CardHeader>
          <CardTitle>Actividades</CardTitle>
          <CardDescription> Datos obtenidos desde Strava API </CardDescription>
        </CardHeader>

        <CardContent>
          {
            !token && (
              <div class="flex items-center gap-3">
                <Spinner class="size-4" />
                <p class="text-sm text-muted-foreground">
                  Conecta con Strava para cargar actividades
                </p>
              </div>
            )
          }

          {
            token && !activities && (
              <p class="text-sm text-red-500">Error cargando actividades</p>
            )
          }

          {
            activities && activities.length === 0 && (
              <p class="text-sm text-muted-foreground">
                No hay actividades disponibles
              </p>
            )
          }

          {
            activities && activities.length > 0 && (
              <ul class="space-y-3">
                {activities.slice(0, 5).map((a: any) => (
                  <li class="rounded-lg border p-4 space-y-1">
                    <div class="flex justify-between items-center">
                      <p class="font-medium">{a.name}</p>
                      <span class="text-xs text-muted-foreground">
                        {a.date}
                      </span>
                    </div>

                    <p class="text-sm text-muted-foreground">
                      {a.distance_km} km · {a.duration_min} min ·{' '}
                      {a.elevation_m} m
                    </p>

                    <p class="text-xs text-muted-foreground">
                      {a.avg_speed_kmh} km/h
                      {a.avg_hr && ` · ${a.avg_hr} bpm`}
                    </p>
                  </li>
                ))}
              </ul>
            )
          }
        </CardContent>

        <CardFooter>
          <p class="text-sm text-muted-foreground">
            Mostrando últimas actividades
          </p>
        </CardFooter>
      </Card>
    </section>
  </main>
</Layout>

<script>
  const url = new URL(window.location.href)
  if (url.searchParams.has('token')) {
    url.searchParams.delete('token')
    window.history.replaceState({}, '', url)
  }
</script>
